          <mxGeometry x="60" y="370" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="cart_attrs" value="PK  id : BIGINT AUTO_INCREMENT&#xa;FK  customerId : BIGINT UNIQUE&#xa;      createdAt : DATETIME" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="cart">
          <mxGeometry y="30" width="250" height="80" as="geometry" />
