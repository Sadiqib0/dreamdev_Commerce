          <mxGeometry x="60" y="80" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="notification_attrs" value="PK  id : BIGINT AUTO_INCREMENT&#xa;FK  userId : BIGINT&#xa;      message : TEXT&#xa;      status : ENUM(UNREAD,READ)&#xa;      createdAt : DATETIME" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="notification">
          <mxGeometry y="30" width="250" height="130" as="geometry" />
        </mxCell>

