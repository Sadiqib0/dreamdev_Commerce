        <mxCell id="r_order_oi" value="contains&#xa;1        *" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERmandOne;endFill=0;startFill=0;strokeColor=#9673a6;strokeWidth=2;fontSize=11;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="ord" target="orderitem">
