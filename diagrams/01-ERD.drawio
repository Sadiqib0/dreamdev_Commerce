  <diagram name="ERD - Entity Relationship Diagram" id="erd-diagram">
    <mxGraphModel dx="1800" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="DreamCommerce - Entity Relationship Diagram" style="text;html=1;fontSize=20;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="14" width="760" height="40" as="geometry" />
        </mxCell>

        <mxCell id="user" value="User" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="80" width="240" height="210" as="geometry" />
        </mxCell>
        <mxCell id="user_attrs" value="PK  id : BIGINT AUTO_INCREMENT&#xa;      name : VARCHAR(100) NOT NULL&#xa;      email : VARCHAR(255) UNIQUE&#xa;      password : VARCHAR(255)&#xa;      role : ENUM(CUSTOMER,VENDOR,ADMIN)&#xa;      verified : BOOLEAN DEFAULT FALSE&#xa;      createdAt : DATETIME" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="user">
          <mxGeometry y="30" width="240" height="180" as="geometry" />
        </mxCell>

        <mxCell id="product" value="Product" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="80" width="260" height="290" as="geometry" />
        </mxCell>
        <mxCell id="product_attrs" value="PK  id : BIGINT AUTO_INCREMENT&#xa;FK  vendorId : BIGINT&#xa;      name : VARCHAR(255) NOT NULL&#xa;      description : TEXT&#xa;      price : DECIMAL(10,2) NOT NULL&#xa;      imageUrl : VARCHAR(500)&#xa;      category : VARCHAR(100)&#xa;      stock : INT&#xa;      status : ENUM(ACTIVE,INACTIVE)&#xa;      createdAt : DATETIME" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="product">
          <mxGeometry y="30" width="260" height="260" as="geometry" />
