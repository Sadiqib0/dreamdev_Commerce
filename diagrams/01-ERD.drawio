          <mxGeometry x="1330" y="80" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="legend_attrs" value="PK = Primary Key (first row)&#xa;FK = Foreign Key&#xa;| —— Many-to-One&#xa;&lt;— One-to-Many (crow&#x27;s foot)" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry y="26" width="200" height="84" as="geometry" />
