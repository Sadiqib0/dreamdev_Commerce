          <mxGeometry x="440" y="720" width="240" height="190" as="geometry" />
        </mxCell>
        <mxCell id="payment_attrs" value="PK  id : BIGINT AUTO_INCREMENT&#xa;FK  orderId : BIGINT UNIQUE&#xa;      amount : DECIMAL(10,2)&#xa;      status : ENUM(PENDING,COMPLETED,...)&#xa;      method : ENUM(CARD,BANK_TRANSFER,...)&#xa;      createdAt : DATETIME" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="payment">
