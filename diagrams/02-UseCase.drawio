        <mxCell id="system_boundary" value="&lt;b&gt;DreamCommerce E-Commerce System&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;fontSize=14;fontColor=#333333;verticalAlign=top;dashed=0;rounded=1;" vertex="1" parent="1">
